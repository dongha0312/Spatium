# 3D 생성(GPU 작업) 사용자별 횟수 제한 (프론트엔드 UX 제한)
#  - CRA는 빌드 시점에 REACT_APP_* 값을 코드에 주입한다. 값을 바꾸면 재빌드 필요.
#  - 이 값들은 브라우저에 노출되며 localStorage 기반이라 우회 가능하다.
#    실질적 GPU 남용 차단은 백엔드에서 해야 하며, 여기는 실수/과도한 연타 방지용이다.

# 짧은 시간 창(분) 안에 허용하는 생성 횟수 → "3분에 1회"
REACT_APP_GPU_LIMIT_WINDOW_MIN=3
REACT_APP_GPU_LIMIT_PER_WINDOW=1

# 하루(24시간) 동안 허용하는 총 생성 횟수 → "하루 5회"
REACT_APP_GPU_LIMIT_PER_DAY=5
