# Fully local WSL provider defaults. No remote 3D API is used.
IMAGE_TO_3D_PROVIDER=local_triposr
LOCAL_TRIPOSR_REPO_DIR=vendor/TripoSR
LOCAL_TRIPOSR_PYTHON=.venv/bin/python
LOCAL_TRIPOSR_MODEL_PATH=vendor/weights/TripoSR
LOCAL_TRIPOSR_DEVICE=cuda:0
LOCAL_TRIPOSR_TIMEOUT_SECONDS=600

# Free local background removal. Download this weight once during WSL setup.
YOLO_SEGMENTATION_MODEL=vendor/weights/yolo/yolo11s-seg.pt
YOLO_SEGMENTATION_DEVICE=auto
YOLO_SEGMENTATION_CONFIDENCE=0.25

MAX_UPLOAD_BYTES=10485760
