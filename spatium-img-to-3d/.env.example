HOST=127.0.0.1
PORT=8000
AI_INTERNAL_API_KEY=
RELOAD=false
LOG_LEVEL=INFO

# Fully local WSL provider defaults. No remote 3D API is used.
IMAGE_TO_3D_PROVIDER=local_triposr
LOCAL_TRIPOSR_REPO_DIR=vendor/TripoSR
LOCAL_TRIPOSR_PYTHON=.venv/bin/python
LOCAL_TRIPOSR_MODEL_PATH=vendor/weights/TripoSR
LOCAL_TRIPOSR_DEVICE=cuda:0
LOCAL_TRIPOSR_TIMEOUT_SECONDS=600

# Free local Stable Fast 3D. Run scripts/setup_local_sf3d.sh once.
LOCAL_SF3D_REPO_DIR=vendor/stable-fast-3d
LOCAL_SF3D_PYTHON=.venv-sf3d/bin/python
LOCAL_SF3D_MODEL_PATH=vendor/weights/stable-fast-3d
LOCAL_SF3D_DEVICE=cuda
LOCAL_SF3D_TIMEOUT_SECONDS=600

# Hugging Face read token used only by the one-time setup script.
# First accept the model license at https://huggingface.co/stabilityai/stable-fast-3d
HF_TOKEN=hf_your_token_here

# Free local background removal. Download this weight once during WSL setup.
YOLO_SEGMENTATION_MODEL=vendor/weights/yolo/yolo11s-seg.pt
YOLO_SEGMENTATION_DEVICE=auto
YOLO_SEGMENTATION_CONFIDENCE=0.25

# Optional natural-language segmentation pipeline (isolated local environment)
GROUNDED_SAM2_PYTHON=.venv-segmentation/bin/python
GROUNDING_DINO_MODEL=vendor/weights/grounding-dino-tiny
SAM2_MODEL=vendor/weights/sam2.1-hiera-small
KO_EN_TRANSLATION_MODEL=vendor/weights/opus-mt-ko-en
GROUNDED_SAM2_DEVICE=cuda
GROUNDING_DINO_BOX_THRESHOLD=0.30
GROUNDING_DINO_TEXT_THRESHOLD=0.25
GROUNDED_SAM2_TIMEOUT_SECONDS=600

# Generated GLB axis correction for Three.js (Y-up). Set false to keep raw output.
AUTO_ORIENT_GLB_FOR_THREEJS=true
GLB_ROTATION_X_DEGREES=-90

MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_PIXELS=40000000
GPU_MAX_CONCURRENCY=1
